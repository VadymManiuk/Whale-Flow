{
  "name": "whale-flow-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "bot": "tsx src/cli.ts",
    "telegram:test": "tsx src/cli.ts telegram:test",
    "telegram:test:prod": "node dist/cli.js telegram:test",
    "health": "tsx src/cli.ts health",
    "health:prod": "node dist/cli.js health",
    "start:prod": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "dotenv": "^16.6.1",
    "ioredis": "^5.6.1",
    "pino": "^9.7.0",
    "telegraf": "^4.16.3",
    "viem": "^2.31.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.16.0",
    "eslint": "^9.30.0",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4"
  }
}
